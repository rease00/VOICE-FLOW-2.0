{
  "name": "v-flow-ai-site-lock",
  "main": "src/index.js",
  "compatibility_date": "2026-04-04",
  "vars": {
    "SITE_LOCK_PROTECTED_HOSTS": "v-flow-ai.com,www.v-flow-ai.com"
  },
  "routes": [
    {
      "pattern": "v-flow-ai.com/*",
      "zone_name": "v-flow-ai.com"
    },
    {
      "pattern": "www.v-flow-ai.com/*",
      "zone_name": "v-flow-ai.com"
    }
  ]
}
