{
  "name": "cloudrun-2vcpu",
  "description": "Production capacity contract for a 2 vCPU Cloud Run topology with a single public API region, dedicated runtimes, and no session-affinity dependency.",
  "services": {
    "voiceflow-api": {
      "cpu": "2",
      "memory": "2Gi",
      "minInstances": 0,
      "maxInstances": 20,
      "concurrency": 16,
      "allowUnauthenticated": true,
      "ingress": "all",
      "sessionAffinity": false
    },
    "voiceflow-gemini-runtime": {
      "cpu": "2",
      "memory": "2Gi",
      "minInstances": 0,
      "maxInstances": 10,
      "concurrency": 2,
      "allowUnauthenticated": false,
      "ingress": "internal",
      "sessionAffinity": false
    },
    "voiceflow-vertex-text-runtime": {
      "cpu": "2",
      "memory": "2Gi",
      "minInstances": 0,
      "maxInstances": 10,
      "concurrency": 2,
      "allowUnauthenticated": false,
      "ingress": "internal",
      "sessionAffinity": false
    }
  },
  "rolloutOrder": [
    "voiceflow-gemini-runtime",
    "voiceflow-vertex-text-runtime",
    "voiceflow-api"
  ],
  "canary": {
    "steps": [10, 50, 100],
    "soakSeconds": 180,
    "maxQueueDepth": 60,
    "maxOldestQueuedAgeMs": 60000
  },
  "loadTest": {
    "concurrency": 12,
    "requests": 12,
    "maxQueueDepth": 80,
    "maxOldestQueuedAgeMs": 60000,
    "minCompletionRate": 1
  }
}
