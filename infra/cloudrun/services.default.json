{
  "region": "us-central1",
  "artifactRegistryRepo": "voiceflow",
  "services": [
    {
      "name": "voiceflow-gemini-runtime",
      "imageName": "voiceflow-gemini-runtime",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.gemini-runtime",
      "ingress": "internal",
      "allowUnauthenticated": true,
      "minInstances": 0,
      "maxInstances": 20,
      "concurrency": 4,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 300,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token"
      }
    },
    {
      "name": "voiceflow-kokoro-runtime",
      "imageName": "voiceflow-kokoro-runtime",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.kokoro-runtime",
      "ingress": "internal",
      "allowUnauthenticated": true,
      "minInstances": 0,
      "maxInstances": 20,
      "concurrency": 2,
      "cpu": "4",
      "memory": "8Gi",
      "timeoutSeconds": 900,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "KOKORO_DEVICE": "cpu",
        "KOKORO_IDLE_UNLOAD_MS": "120000",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {}
    },
    {
      "name": "voiceflow-voice-transfer-runtime",
      "imageName": "voiceflow-voice-transfer-runtime",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.voice-transfer-runtime",
      "ingress": "internal",
      "allowUnauthenticated": true,
      "minInstances": 0,
      "maxInstances": 10,
      "concurrency": 1,
      "cpu": "4",
      "memory": "8Gi",
      "timeoutSeconds": 1200,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "VF_VOICE_TRANSFER_DEVICE": "cpu:0",
        "VF_VOICE_TRANSFER_ONNX_PROVIDER": "openvino",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {}
    },
    {
      "name": "voiceflow-api",
      "imageName": "voiceflow-backend",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.backend",
      "ingress": "all",
      "allowUnauthenticated": true,
      "minInstances": 1,
      "maxInstances": 50,
      "concurrency": 80,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 900,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "VF_ENV": "production",
        "VF_SERVICE_ROLE": "api",
        "VF_TTS_QUEUE_WORKER_COUNT": "0",
        "VF_AUTH_ENFORCE": "1",
        "VF_DEV_UID_HEADER_ENABLED": "0",
        "VF_ENABLE_DEV_ADMIN_LOGIN": "0",
        "VF_REDIS_URL": "__REDIS_URL__",
        "VF_GEMINI_RUNTIME_URL": "__GEMINI_RUNTIME_URL__",
        "VF_KOKORO_RUNTIME_URL": "__KOKORO_RUNTIME_URL__",
        "VF_VOICE_TRANSFER_RUNTIME_URL": "__VOICE_TRANSFER_RUNTIME_URL__",
        "VF_WHISPER_DEVICE": "cpu",
        "VF_WHISPER_COMPUTE": "int8",
        "VF_VOICE_TRANSFER_DEVICE": "cpu:0",
        "VF_VOICE_TRANSFER_ONNX_PROVIDER": "openvino",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "FIREBASE_SERVICE_ACCOUNT_JSON": "firebase-service-account-json",
        "STRIPE_SECRET_KEY": "stripe-secret-key",
        "STRIPE_WEBHOOK_SECRET": "stripe-webhook-secret",
        "VF_ADMIN_UNLOCK_SIGNING_SECRET": "vf-admin-unlock-signing-secret",
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token"
      }
    },
    {
      "name": "voiceflow-worker",
      "imageName": "voiceflow-backend",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.backend",
      "ingress": "internal",
      "allowUnauthenticated": true,
      "minInstances": 1,
      "maxInstances": 50,
      "concurrency": 1,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 900,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": true,
      "env": {
        "PORT": "8080",
        "VF_ENV": "production",
        "VF_SERVICE_ROLE": "worker",
        "VF_TTS_QUEUE_WORKER_COUNT": "4",
        "VF_AUTH_ENFORCE": "1",
        "VF_DEV_UID_HEADER_ENABLED": "0",
        "VF_ENABLE_DEV_ADMIN_LOGIN": "0",
        "VF_REDIS_URL": "__REDIS_URL__",
        "VF_GEMINI_RUNTIME_URL": "__GEMINI_RUNTIME_URL__",
        "VF_KOKORO_RUNTIME_URL": "__KOKORO_RUNTIME_URL__",
        "VF_VOICE_TRANSFER_RUNTIME_URL": "__VOICE_TRANSFER_RUNTIME_URL__",
        "VF_WHISPER_DEVICE": "cpu",
        "VF_WHISPER_COMPUTE": "int8",
        "VF_VOICE_TRANSFER_DEVICE": "cpu:0",
        "VF_VOICE_TRANSFER_ONNX_PROVIDER": "openvino",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "FIREBASE_SERVICE_ACCOUNT_JSON": "firebase-service-account-json",
        "VF_ADMIN_UNLOCK_SIGNING_SECRET": "vf-admin-unlock-signing-secret",
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token"
      }
    }
  ]
}
