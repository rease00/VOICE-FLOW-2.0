{
  "region": "us-central1",
  "artifactRegistryRepo": "voiceflow",
  "deploymentProfile": "cloudrun-2vcpu",
  "profileContractPath": "infra/cloudrun/profiles.cloudrun-2vcpu.json",
  "services": [
    {
      "name": "voiceflow-gemini-runtime",
      "imageName": "voiceflow-gemini-runtime",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.gemini-runtime",
      "ingress": "internal",
      "allowUnauthenticated": true,
      "minInstances": 1,
      "maxInstances": 10,
      "concurrency": 2,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 300,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "GEMINI_BATCH_DEFAULT_PARALLEL": "2",
        "GEMINI_BATCH_MAX_PARALLEL": "3",
        "GEMINI_STUDIO_PAIR_GROUP_MAX_CONCURRENCY": "2",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token"
      }
    },
    {
      "name": "voiceflow-kokoro-runtime",
      "imageName": "voiceflow-kokoro-runtime",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.kokoro-runtime",
      "ingress": "internal",
      "allowUnauthenticated": true,
      "minInstances": 0,
      "maxInstances": 6,
      "concurrency": 1,
      "cpu": "2",
      "memory": "4Gi",
      "timeoutSeconds": 900,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "KOKORO_DEVICE": "cpu",
        "KOKORO_IDLE_UNLOAD_MS": "90000",
        "KOKORO_BATCH_DEFAULT_PARALLEL": "1",
        "KOKORO_BATCH_MAX_PARALLEL": "2",
        "KOKORO_MAX_ACTIVE_SYNTH": "1",
        "KOKORO_ORT_INTRA_OP_THREADS": "1",
        "KOKORO_ORT_INTER_OP_THREADS": "1",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {}
    },
    {
      "name": "voiceflow-api",
      "imageName": "voiceflow-backend",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.backend",
      "ingress": "all",
      "allowUnauthenticated": true,
      "minInstances": 1,
      "maxInstances": 20,
      "concurrency": 16,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 900,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "VF_ENV": "production",
        "VF_SERVICE_ROLE": "api",
        "VF_TTS_QUEUE_WORKER_COUNT": "0",
        "VF_TTS_GATEWAY_MAX_ACTIVE": "20",
        "VF_TTS_GATEWAY_QUEUE_MAX": "80",
        "VF_TTS_QUEUE_MAX_DEPTH": "200",
        "VF_AI_OPS_CONCURRENCY_SOFT_LIMIT": "8",
        "VF_AI_OPS_CONCURRENCY_HARD_LIMIT": "12",
        "VF_AUTH_ENFORCE": "1",
        "VF_DEV_UID_HEADER_ENABLED": "0",
        "VF_ENABLE_DEV_ADMIN_LOGIN": "0",
        "VF_REDIS_URL": "__REDIS_URL__",
        "VF_GEMINI_RUNTIME_URL": "__GEMINI_RUNTIME_URL__",
        "VF_KOKORO_RUNTIME_URL": "__KOKORO_RUNTIME_URL__",
        "VF_WHISPER_DEVICE": "cpu",
        "VF_WHISPER_COMPUTE": "int8",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "FIREBASE_SERVICE_ACCOUNT_JSON": "firebase-service-account-json",
        "STRIPE_SECRET_KEY": "stripe-secret-key",
        "STRIPE_WEBHOOK_SECRET": "stripe-webhook-secret",
        "VF_ADMIN_UNLOCK_SIGNING_SECRET": "vf-admin-unlock-signing-secret",
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token"
      }
    },
    {
      "name": "voiceflow-worker",
      "imageName": "voiceflow-backend",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.backend-worker",
      "ingress": "internal",
      "allowUnauthenticated": true,
      "minInstances": 1,
      "maxInstances": 12,
      "concurrency": 1,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 900,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": true,
      "env": {
        "PORT": "8080",
        "VF_ENV": "production",
        "VF_SERVICE_ROLE": "worker",
        "VF_TTS_QUEUE_WORKER_COUNT": "2",
        "VF_TTS_ENGINE_CONCURRENCY_GEM": "2",
        "VF_TTS_ENGINE_CONCURRENCY_KOKORO": "1",
        "VF_TTS_LIVE_SYNTH_CONCURRENCY": "1",
        "VF_TTS_LIVE_LLVC_CONCURRENCY": "1",
        "VF_TTS_LIVE_LLVC_GLOBAL_CONCURRENCY": "1",
        "VF_AUTH_ENFORCE": "1",
        "VF_DEV_UID_HEADER_ENABLED": "0",
        "VF_ENABLE_DEV_ADMIN_LOGIN": "0",
        "VF_REDIS_URL": "__REDIS_URL__",
        "VF_GEMINI_RUNTIME_URL": "__GEMINI_RUNTIME_URL__",
        "VF_KOKORO_RUNTIME_URL": "__KOKORO_RUNTIME_URL__",
        "VF_WHISPER_DEVICE": "cpu",
        "VF_WHISPER_COMPUTE": "int8",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "FIREBASE_SERVICE_ACCOUNT_JSON": "firebase-service-account-json",
        "VF_ADMIN_UNLOCK_SIGNING_SECRET": "vf-admin-unlock-signing-secret",
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token"
      }
    }
  ]
}
