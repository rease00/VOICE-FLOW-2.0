{
  "region": "asia-southeast1",
  "artifactRegistryRepo": "voiceflow",
  "deploymentProfile": "cloudrun-2vcpu",
  "profileContractPath": "infra/cloudrun/profiles.cloudrun-2vcpu.json",
  "services": [
    {
      "name": "voiceflow-gemini-runtime",
      "imageName": "voiceflow-gemini-runtime",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.gemini-runtime",
      "ingress": "internal",
      "allowUnauthenticated": false,
      "sessionAffinity": false,
      "minInstances": 0,
      "maxInstances": 10,
      "concurrency": 2,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 300,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "VF_RUNTIME_NAME": "tts-runtime",
        "VF_RUNTIME_ROLE": "tts_only",
        "VF_TTS_TEXTTOSPEECH_ONLY": "1",
        "GEMINI_BATCH_DEFAULT_PARALLEL": "2",
        "GEMINI_BATCH_MAX_PARALLEL": "3",
        "GEMINI_STUDIO_PAIR_GROUP_MAX_CONCURRENCY": "2",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token"
      }
    },
    {
      "name": "voiceflow-vertex-text-runtime",
      "imageName": "voiceflow-vertex-text-runtime",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.vertex-text-runtime",
      "ingress": "internal",
      "allowUnauthenticated": false,
      "sessionAffinity": false,
      "minInstances": 0,
      "maxInstances": 10,
      "concurrency": 2,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 300,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "VF_RUNTIME_NAME": "vertex-text-runtime",
        "VF_RUNTIME_ROLE": "text_only",
        "VF_RUNTIME_FORCE_AUTH_MODE": "vertex",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token"
      }
    },
    {
      "name": "voiceflow-api",
      "imageName": "voiceflow-backend-api",
      "dockerfile": "infra/cloudrun/docker/Dockerfile.backend",
      "ingress": "all",
      "allowUnauthenticated": true,
      "sessionAffinity": false,
      "minInstances": 0,
      "maxInstances": 20,
      "concurrency": 16,
      "cpu": "2",
      "memory": "2Gi",
      "timeoutSeconds": 900,
      "executionEnvironment": "gen2",
      "startupCpuBoost": true,
      "cpuAlwaysAllocated": false,
      "env": {
        "PORT": "8080",
        "VF_ENV": "production",
        "VF_SERVICE_ROLE": "api",
        "VF_PUBLIC_API_REGIONS": "asia-southeast1",
        "VF_TTS_QUEUE_WORKER_COUNT": "0",
        "VF_TTS_QUEUE_KEY_PREFIX": "vf:tts:v2:jobs",
        "VF_TTS_QUEUE_JOB_TTL_MS": "300000",
        "VF_TTS_GATEWAY_MAX_ACTIVE": "20",
        "VF_TTS_GATEWAY_QUEUE_MAX": "80",
        "VF_TTS_QUEUE_MAX_DEPTH": "200",
        "VF_TTS_QUEUE_MAX_QUEUED_PER_USER": "12",
        "VF_TTS_QUEUE_MAX_QUEUED_PER_LANE": "120",
        "VF_TTS_QUEUE_MIRROR_MAX_JOBS": "500",
        "VF_TTS_QUEUE_RESERVE_ANOMALY_TTL_SEC": "86400",
        "VF_TTS_QUEUE_MAX_RECOVERY_ATTEMPTS": "3",
        "VF_TTS_QUEUE_RETRY_AFTER_SECONDS": "2",
        "VF_TTS_V2_REQUEST_MAX_BODY_BYTES": "524288",
        "VF_TTS_DRAIN_ENABLED": "0",
        "VF_BILLING_WEBHOOK_MAX_BODY_BYTES": "262144",
        "VF_BILLING_WEBHOOK_PROCESSING_LEASE_SECONDS": "900",
        "VF_AI_OPS_CONCURRENCY_SOFT_LIMIT": "8",
        "VF_AI_OPS_CONCURRENCY_HARD_LIMIT": "12",
        "VF_AUTH_ENFORCE": "1",
        "VF_DEV_UID_HEADER_ENABLED": "0",
        "VF_ENABLE_DEV_ADMIN_LOGIN": "0",
        "VF_REDIS_URL": "__REDIS_URL__",
        "VF_TTS_RUNTIME_URL": "__GEMINI_RUNTIME_URL__",
        "VF_VERTEX_TEXT_RUNTIME_URL": "__VERTEX_TEXT_RUNTIME_URL__",
        "VF_VOICE_CLONE_PROVIDER_DEFAULT": "modal",
        "VF_OPENVOICE_PROVIDER_DEFAULT": "modal",
        "VF_VOICE_CLONE_MODAL_RUNTIME_URL": "__VOICE_CLONE_MODAL_RUNTIME_URL__",
        "VF_VOICE_CLONE_RUNTIME_URL": "__VOICE_CLONE_RUNTIME_URL__",
        "VF_OPENVOICE_MODAL_RUNTIME_URL": "__OPENVOICE_MODAL_RUNTIME_URL__",
        "VF_OPENVOICE_RUNTIME_URL": "__OPENVOICE_MODAL_RUNTIME_URL__",
        "VF_WHISPER_DEVICE": "cpu",
        "VF_WHISPER_COMPUTE": "int8",
        "CUDA_VISIBLE_DEVICES": ""
      },
      "secretEnv": {
        "FIREBASE_SERVICE_ACCOUNT_JSON": "firebase-service-account-json",
        "STRIPE_SECRET_KEY": "stripe-secret-key",
        "STRIPE_WEBHOOK_SECRET": "stripe-webhook-secret",
        "VF_ADMIN_UNLOCK_SIGNING_SECRET": "vf-admin-unlock-signing-secret",
        "GEMINI_RUNTIME_ADMIN_TOKEN": "gemini-runtime-admin-token",
        "VF_VOICE_CLONE_MODAL_RUNTIME_TOKEN": "voice-clone-runtime-token",
        "VF_VOICE_CLONE_RUNTIME_TOKEN": "voice-clone-runtime-token",
        "VF_VOICE_CLONE_ARTIFACT_SECRET": "voice-clone-artifact-secret",
        "VF_OPENVOICE_MODAL_RUNTIME_TOKEN": "openvoice-runtime-token",
        "VF_OPENVOICE_RUNTIME_TOKEN": "openvoice-runtime-token",
        "VF_OPENVOICE_ARTIFACT_SECRET": "openvoice-artifact-secret"
      }
    }
  ]
}
