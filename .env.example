# Hugging Face token (optional, needed for private HF model downloads)
HF_TOKEN=hf_your_token_here

# Enable only if you explicitly want cloud fallback ASR when Whisper is unavailable
VF_ENABLE_GOOGLE_ASR_FALLBACK=0

# Restrict CORS to local UI origins (comma-separated list when overriding)
# VF_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Gemini runtime API key pool (comma/newline separated). Used for key rotation + rate-limit fallback.
# GEMINI_API_KEYS=AIzaKeyA,AIzaKeyB,AIzaKeyC
# Preferred file-based Gemini key pool for multi-key rotation (one key per line or comma/newline separated).
# Example (Windows): GEMINI_API_KEYS_FILE=C:\Users\1wasi\OneDrive\Desktop\voice-Flow\API.txt
# GEMINI_API_KEYS_FILE=
# Optional single-key fallback if pool is not set.
# GEMINI_API_KEY=AIzaSingleKeyFallback
# Optional key scheduler tuning for Gemini runtime.
# GEMINI_KEY_COOLDOWN_BASE_MS=8000
# GEMINI_KEY_COOLDOWN_MAX_MS=120000
# GEMINI_KEY_RETRY_LIMIT=8
# GEMINI_KEY_WAIT_SLICE_MS=1000
# Optional admin telemetry caps (requests/day):
# GEMINI_KEY_DAILY_LIMIT=1500
# GEMINI_POOL_OVERALL_DAILY_LIMIT=96000

# Firebase web SDK (frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Canonical frontend gateway URL (defaults to http://127.0.0.1:7800 when unset).
VITE_API_BASE_URL=http://127.0.0.1:7800
# Optional admin login mapping + allowlists (frontend)
# If local admin env is missing, login with username "admin" will fallback to Firebase email auth.
VITE_ADMIN_LOGIN_EMAIL=
VITE_ADMIN_EMAIL_ALLOWLIST=
VITE_ADMIN_UID_ALLOWLIST=
# Frontend production hardening flags.
# Local admin login and x-dev-uid forwarding are DEV-only controls and MUST remain 0 in production.
VITE_ENABLE_LOCAL_ADMIN_DEV_LOGIN=0
VITE_ENABLE_DEV_UID_HEADER=0
# Dev server hardening: keep loopback + bootstrap endpoint disabled unless explicitly needed in local dev.
VITE_DEV_SERVER_EXPOSE=0
VITE_ENABLE_LOCAL_BOOTSTRAP_ENDPOINT=0
# Required when VITE_ENABLE_LOCAL_BOOTSTRAP_ENDPOINT=1.
VF_DEV_BOOTSTRAP_TOKEN=
# Optional release tag attached to frontend telemetry.
VITE_APP_RELEASE=
# Optional frontend telemetry sampling controls.
VITE_FRONTEND_OBSERVABILITY_ENABLED=1
VITE_FRONTEND_ERROR_SAMPLE_RATE=1
VITE_WEB_VITALS_SAMPLE_RATE=0.25
# UI rollout controls (query/localStorage can override these defaults).
# VITE_UI_REFACTOR_ENABLED=1
# VITE_UI_BACKGROUND_DEFAULT_MODE=auto
# Optional Firestore fallback for admin status:
# users/{uid} can include one of: isAdmin=true, admin=true, role="admin", roles=["admin"]

# Local encrypted admin login (frontend)
# This mode is intended for local development only.
# Requires BOTH VITE_ENABLE_LOCAL_ADMIN_DEV_LOGIN=1 and backend auth enforcement OFF (VF_AUTH_ENFORCE=0).
VITE_LOCAL_ADMIN_USERNAME=admin
VITE_LOCAL_ADMIN_UID=local_admin
VITE_LOCAL_ADMIN_PASSWORD_HASH_B64=
VITE_LOCAL_ADMIN_PASSWORD_SALT_B64=
VITE_LOCAL_ADMIN_PBKDF2_ITERATIONS=210000
VITE_LOCAL_ADMIN_SESSION_TTL_MIN=480
VITE_LOCAL_ADMIN_SESSION_KEY_B64=

# Firebase Admin + auth enforcement (backend)
# Option A (recommended): rely on GOOGLE_APPLICATION_CREDENTIALS file path
# Example (Windows): GOOGLE_APPLICATION_CREDENTIALS=C:\Users\1wasi\OneDrive\Desktop\firebase-adminsdk.json
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: inline JSON credential payload in FIREBASE_SERVICE_ACCOUNT_JSON
FIREBASE_SERVICE_ACCOUNT_JSON=
# Enable Firestore-backed storage (set to 0 to force in-memory fallback mode).
VF_FIRESTORE_ENABLE=1
# Production requirement: keep auth enforcement ON.
# Local dev-only bypass mode requires explicit override to 0.
VF_AUTH_ENFORCE=1
VF_DEV_BYPASS_UID=dev_local_user
VF_DAILY_GENERATION_LIMIT=30
VF_AD_REWARD_CLAIM_LIMIT_PER_DAY=3
VF_AD_REWARD_VFF_AMOUNT=1000
VF_GENERATION_HISTORY_MAX_ITEMS=200
VF_GENERATION_HISTORY_PREVIEW_CHARS=220
VF_TTS_QUEUE_RESULT_TTL_MS=900000
VF_TTS_JOB_INLINE_RESULT_MAX_BYTES=1048576
# Persist profile/userId fallback locally when Firestore is unavailable.
VF_USER_PROFILE_FALLBACK_PERSIST=1
VF_USER_PROFILE_FALLBACK_FILE=backend/artifacts/user_profile_fallback.json

# Phase 2 SaaS control-plane flags (recommended production defaults)
VF_RBAC_ENABLED=1
VF_RBAC_ENFORCE=1
VF_AUDIT_LEDGER_ENABLED=1
VF_ALERT_ENGINE_ENABLED=1
VF_SCHEDULER_ENABLED=1
VF_ANALYTICS_V2_ENABLED=1
VF_SCHEDULER_LOCK_TTL_SECONDS=45
VF_SCHEDULER_TICK_SECONDS=60
VF_ALERT_EVAL_INTERVAL_SECONDS=60

# Stripe billing (backend)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_INR=
STRIPE_PRICE_PLUS_INR=
VF_TOKEN_PACK_BASE_INR=499
# Coupon defaults (backend)
VF_COUPON_DEFAULT_VALIDITY_MONTHS=6
VF_COUPON_RESERVATION_TTL_MINUTES=45
# Dev-only escape hatch; keep OFF in production.
VF_ADMIN_COUPON_LIMIT_BYPASS=0

# Optional per-service Python interpreter overrides for hard-isolated venvs.
# LLVC runtime requires Python 3.11.x.
# VF_PYTHON_BIN_MEDIA_BACKEND=
# VF_PYTHON_BIN_GEMINI_RUNTIME=
# VF_PYTHON_BIN_KOKORO_RUNTIME=
# VF_PYTHON_BIN_LLVC_RUNTIME=

# Runtime concurrency autotune (bootstrap-services)
VF_AUTO_TUNE_WORKERS=1
VF_CONCURRENCY_PROFILE=balanced
VF_HOST_RESERVED_CPUS=2

# dev-all shutdown policy (0 = auto-stop services on shutdown)
VF_DEV_KEEP_SERVICES=0

# Internal LLVC runtime URL used by media-backend proxy + post-TTS conversion.
VF_LLVC_RUNTIME_URL=http://127.0.0.1:7830
# Shared admin token required by Gemini runtime /v1/admin/api-pool* endpoints.
GEMINI_RUNTIME_ADMIN_TOKEN=
VF_LLVC_MODELS_DIR=backend/models/llvc
VF_LLVC_DEVICE=cpu

# Universal post-TTS conversion (media-backend -> llvc-runtime)
VF_TTS_POST_LLVC_ENABLED=1
VF_TTS_POST_LLVC_REQUIRED=1
VF_TTS_POST_LLVC_PRESET=llvc_hq_cpu
VF_LLVC_PRESET_DEFAULT=llvc_hq_cpu
VF_LLVC_STREAM_DEFAULT=0
VF_LLVC_CHUNK_FACTOR=2
VF_LLVC_MODEL_REGISTRY_FILE=backend/config/llvc_model_registry.json
# Kokoro hard stop for long-running synthesis requests (milliseconds)
KOKORO_SYNTH_MAX_MS=180000
# Post-run CPU audit controls
VF_CPU_AUDIT_THRESHOLD_PCT=60
VF_CPU_AUDIT_SAMPLE_SEC=8
VF_TOKEN_PACK_VF_AMOUNT=100000
STRIPE_CHECKOUT_SUCCESS_URL=http://127.0.0.1:3000?billing=success
STRIPE_CHECKOUT_CANCEL_URL=http://127.0.0.1:3000?billing=cancel
STRIPE_PORTAL_RETURN_URL=http://127.0.0.1:3000

# AI Guardian (backend ops automation)
VF_AI_OPS_MODE=observe
VF_AI_OPS_ENABLE_AUTOFIX_MINOR=0
VF_AI_OPS_CONCURRENCY_SOFT_LIMIT=24
VF_AI_OPS_CONCURRENCY_HARD_LIMIT=32
VF_AI_OPS_AUTOFIX_COOLDOWN_MS=180000
VF_ADMIN_APPROVAL_TOKEN=
# Comma-separated admin UIDs allowed to approve major actions.
VF_ADMIN_APPROVER_UIDS=
