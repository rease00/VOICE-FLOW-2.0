# Hugging Face token (optional, needed for private HF model downloads)
HF_TOKEN=hf_your_token_here

# Force Kokoro onto the local Python runtime in CPU mode.
# Global GPU bootstrap still applies to eligible non-Kokoro services.
# KOKORO_DEVICE is retained for compatibility, but Kokoro ignores non-CPU values.
VF_DEV_BOOTSTRAP_MODE=cpu
VF_KOKORO_RUNTIME_URL=http://127.0.0.1:7820
KOKORO_DEVICE=cpu
CUDA_VISIBLE_DEVICES=

# Enable only if you explicitly want cloud fallback ASR when Whisper is unavailable
VF_ENABLE_GOOGLE_ASR_FALLBACK=0

# Restrict CORS to local UI origins (comma-separated list when overriding)
# VF_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Gemini/Vertex text + TTS runtime uses exactly three backend-held service-account slots.
# Configure the slot files on the backend host and keep them out of the repo.
# Optional Vertex defaults (used when sourcePolicy.provider=vertex).
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# Optional service-account file path root used by backend + runtime.
# VF_GEMINI_VERTEX_SECRET_DIR=
# Global default text model for assistant/director/translation text generation.
VF_AI_TEXT_DEFAULT_MODEL=gemini-3.1-flash-lite-preview
# Optional per-domain overrides (inherit from VF_AI_TEXT_DEFAULT_MODEL when unset):
# VF_DUB_DIRECTOR_MODEL=
# VF_READER_TRANSLATION_MODEL=
# VF_TTS_LIVE_NATIVE_DIRECTOR_MODEL=
# VF_PODCAST_STANDARD_SCRIPT_MODEL=
# Optional admin telemetry caps (requests/day):
# GEMINI_KEY_DAILY_LIMIT=1500
# GEMINI_POOL_OVERALL_DAILY_LIMIT=96000

# Firebase web SDK (frontend, Next.js public env)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Transitional Vite compatibility aliases. Remove once all frontend env files use NEXT_PUBLIC_* keys.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional Firebase email verification return URL override.
# Default behavior returns users to the current app path with vf-screen=login.
VITE_AUTH_EMAIL_VERIFY_CONTINUE_URL=
# Canonical frontend gateway URL (defaults to http://127.0.0.1:7800 when unset).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:7800
VITE_API_BASE_URL=http://127.0.0.1:7800
# Browser Kokoro (WebGPU-only) controls.
# Keep enabled to allow strict client-side Kokoro execution.
VITE_ENABLE_BROWSER_KOKORO=1
# Optional CDN/static base URL for Kokoro model assets (config/tokenizer/onnx/voices).
# Default points to Hugging Face model assets when unset.
VITE_KOKORO_MODEL_ASSET_BASE_URL=
# Optional model repo/revision overrides for Kokoro browser runtime.
VITE_KOKORO_MODEL_REPO_ID=onnx-community/Kokoro-82M-v1.0-ONNX
VITE_KOKORO_MODEL_REVISION=main
# Bump this to invalidate browser CacheStorage after model asset changes.
VITE_KOKORO_MODEL_CACHE_VERSION=kokoro-webgpu-q8-v1
# Optional admin allowlists (frontend)
NEXT_PUBLIC_ADMIN_LOGIN_EMAIL=
NEXT_PUBLIC_ADMIN_EMAIL_ALLOWLIST=
NEXT_PUBLIC_ADMIN_UID_ALLOWLIST=
VITE_ADMIN_LOGIN_EMAIL=
VITE_ADMIN_EMAIL_ALLOWLIST=
VITE_ADMIN_UID_ALLOWLIST=
# Frontend production hardening flags.
# Keep x-dev-uid forwarding disabled in production.
NEXT_PUBLIC_ENABLE_DEV_UID_HEADER=0
VITE_ENABLE_DEV_UID_HEADER=0
# Dev server hardening: keep loopback + bootstrap endpoint disabled unless explicitly needed in local dev.
VITE_DEV_SERVER_EXPOSE=0
VITE_ENABLE_LOCAL_BOOTSTRAP_ENDPOINT=0
# Required when VITE_ENABLE_LOCAL_BOOTSTRAP_ENDPOINT=1.
VF_DEV_BOOTSTRAP_TOKEN=
# Optional release tag attached to frontend telemetry.
VITE_APP_RELEASE=
# Optional frontend telemetry sampling controls.
NEXT_PUBLIC_FRONTEND_OBSERVABILITY_ENABLED=1
NEXT_PUBLIC_FRONTEND_ERROR_SAMPLE_RATE=1
VITE_FRONTEND_OBSERVABILITY_ENABLED=1
VITE_FRONTEND_ERROR_SAMPLE_RATE=1
VITE_WEB_VITALS_SAMPLE_RATE=0.25
# UI rollout controls (query/localStorage can override these defaults).
# VITE_UI_REFACTOR_ENABLED=1
# VITE_UI_BACKGROUND_DEFAULT_MODE=auto
# Feature flags for optional modules.
# Optional Firestore fallback for admin status:
# users/{uid} can include one of: isAdmin=true, admin=true, role="admin", roles=["admin"]

# Firebase Admin + auth enforcement (backend)
# Option A (recommended): rely on GOOGLE_APPLICATION_CREDENTIALS file path
# Example (Windows): GOOGLE_APPLICATION_CREDENTIALS=C:\Users\1wasi\OneDrive\Desktop\firebase-adminsdk.json
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: inline JSON credential payload in FIREBASE_SERVICE_ACCOUNT_JSON
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional local-dev auto-seed for allowlisted Firebase admin accounts.
VF_DEV_AUTO_SEED_FIREBASE_ADMINS=0
# Password used by backend/scripts/firebase_seed_admins.py when seeding allowlisted admins.
FIREBASE_SEED_ADMIN_PASSWORD=
# Enable Firestore-backed storage (set to 0 to force in-memory fallback mode).
VF_FIRESTORE_ENABLE=1
# Production requirement: keep auth enforcement ON.
# Local dev-only bypass mode requires explicit override to 0.
VF_AUTH_ENFORCE=1
# Require Firebase email-based accounts to verify email before protected API usage.
# Applies only when VF_AUTH_ENFORCE=1.
VF_REQUIRE_EMAIL_VERIFIED=1
VF_DEV_BYPASS_UID=dev_local_user
VF_DAILY_GENERATION_LIMIT=30
VF_AD_REWARD_CLAIM_LIMIT_PER_DAY=3
VF_AD_REWARD_VFF_AMOUNT=1000
VF_GENERATION_HISTORY_MAX_ITEMS=200
VF_GENERATION_HISTORY_PREVIEW_CHARS=220
VF_TTS_QUEUE_RESULT_TTL_MS=900000
VF_TTS_JOB_INLINE_RESULT_MAX_BYTES=1048576
# Persist profile/userId fallback locally when Firestore is unavailable.
VF_USER_PROFILE_FALLBACK_PERSIST=1
VF_USER_PROFILE_FALLBACK_FILE=backend/artifacts/user_profile_fallback.json

# Phase 2 SaaS control-plane flags (recommended production defaults)
VF_RBAC_ENABLED=1
VF_RBAC_ENFORCE=1
VF_AUDIT_LEDGER_ENABLED=1
VF_ALERT_ENGINE_ENABLED=1
VF_SCHEDULER_ENABLED=1
VF_ANALYTICS_V2_ENABLED=1
VF_SCHEDULER_LOCK_TTL_SECONDS=45
VF_SCHEDULER_TICK_SECONDS=60
VF_ALERT_EVAL_INTERVAL_SECONDS=60
VF_NOTIFICATIONS_EMAIL_ENABLED=0
VF_NOTIFICATIONS_EMAIL_FROM=Voice Flow <notifications@voiceflow.local>
VF_NOTIFICATIONS_EMAIL_REPLY_TO=
VF_NOTIFICATIONS_JOB_EMAIL_MIN_DURATION_MS=90000
RESEND_API_KEY=

# Stripe billing (backend)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Canonical paid plans (all-inclusive INR): first cycle max-bill then loyalty recurring.
STRIPE_PRICE_STARTER_MAX_INR=
STRIPE_PRICE_STARTER_RECURRING_INR=
STRIPE_PRICE_CREATOR_MAX_INR=
STRIPE_PRICE_CREATOR_RECURRING_INR=
STRIPE_PRICE_PRO_MAX_INR=
STRIPE_PRICE_PRO_RECURRING_INR=
STRIPE_PRICE_SCALE_MAX_INR=
STRIPE_PRICE_SCALE_RECURRING_INR=
# Token pack matrix (hard-coded pricing in backend):
# micro 50k=550, standard 150k=1450, mega 300k=2900, ultra 600k=5200
# Coupon defaults (backend)
VF_COUPON_DEFAULT_VALIDITY_MONTHS=6
VF_COUPON_RESERVATION_TTL_MINUTES=45
# Dev-only escape hatch; keep OFF in production.
VF_ADMIN_COUPON_LIMIT_BYPASS=0

# Optional per-service Python interpreter overrides for hard-isolated venvs.
# VF_PYTHON_BIN_MEDIA_BACKEND=
# VF_PYTHON_BIN_GEMINI_RUNTIME=
# VF_PYTHON_BIN_KOKORO_RUNTIME=

# Runtime concurrency autotune (bootstrap-services)
VF_AUTO_TUNE_WORKERS=1
VF_CONCURRENCY_PROFILE=balanced
VF_HOST_RESERVED_CPUS=2

# dev-all shutdown policy (0 = auto-stop services on shutdown)
VF_DEV_KEEP_SERVICES=0

# Shared admin token required by Gemini runtime read-only slot status endpoints.
GEMINI_RUNTIME_ADMIN_TOKEN=
# Kokoro hard stop for long-running synthesis requests (milliseconds)
KOKORO_SYNTH_MAX_MS=180000
# Post-run CPU audit controls
VF_CPU_AUDIT_THRESHOLD_PCT=60
VF_CPU_AUDIT_SAMPLE_SEC=8
VF_TOKEN_PACK_VF_AMOUNT=100000
STRIPE_CHECKOUT_SUCCESS_URL=http://127.0.0.1:3000?billing=success
STRIPE_CHECKOUT_CANCEL_URL=http://127.0.0.1:3000?billing=cancel
STRIPE_PORTAL_RETURN_URL=http://127.0.0.1:3000

# Admin accounting (backend)
VF_ACCOUNTING_CURRENCY=INR
VF_ACCOUNTING_TIMEZONE=Asia/Kolkata
VF_ACCOUNTING_FX_RATES={"INR":1.0,"USD":83.0,"EUR":90.0,"GBP":105.0}
VF_ACCOUNTING_BQ_PROJECT=
VF_ACCOUNTING_BQ_DATASET=
VF_ACCOUNTING_BQ_TABLE=
VF_ACCOUNTING_BQ_BILLING_PROJECT_FILTER=
VF_ACCOUNTING_BQ_CLOUD_RUN_SERVICE_FILTER=
VF_ACCOUNTING_BQ_QUERY_MAX_DAYS=120
VF_ACCOUNTING_GEMINI_PROMPT_INR_PER_1K=0.02
VF_ACCOUNTING_GEMINI_OUTPUT_INR_PER_1K=0.05
VF_ACCOUNTING_GEMINI_FALLBACK_TOKENS_PER_CHAR=0.28
VF_ACCOUNTING_MONITOR_ENABLED=1
VF_ACCOUNTING_MONITOR_UNPAID_GROWTH_PCT=20
VF_ACCOUNTING_MONITOR_MARGIN_FLOOR_PCT=8
VF_ACCOUNTING_MONITOR_COST_SPIKE_MULTIPLIER=1.6
VF_ACCOUNTING_MONITOR_SPIKE_LOOKBACK_DAYS=14
VF_ACCOUNTING_MONITOR_DAILY_CRON=30 2 * * *
VF_ACCOUNTING_MONITOR_DAILY_TIMEZONE=Asia/Kolkata

# AI Guardian (backend ops automation)
VF_AI_OPS_MODE=observe
VF_AI_OPS_ENABLE_AUTOFIX_MINOR=0
VF_AI_OPS_CONCURRENCY_SOFT_LIMIT=24
VF_AI_OPS_CONCURRENCY_HARD_LIMIT=32
VF_AI_OPS_AUTOFIX_COOLDOWN_MS=180000
VF_ADMIN_APPROVAL_TOKEN=
# Comma-separated admin UIDs allowed to approve major actions.
VF_ADMIN_APPROVER_UIDS=
# Optional comma-separated admin emails allowed to bypass email-verification middleware for admin access.
VF_ADMIN_APPROVER_EMAILS=
