# Exclude VCS and local tooling metadata
.git
.gitignore
.gitattributes
.vscode
.cursor
.playwright-cli

# Exclude local dependencies/venvs/build outputs
node_modules
frontend/node_modules
backend/node_modules
.venvs
backend/.venvs
dist
frontend/dist
artifacts
output
tmp_dir
mcp-after-revert
mcp-before-revert

# Exclude local caches and logs
.pytest_cache
.runtime
backend/.runtime
**/__pycache__
**/*.pyc
*.log
debug-*.log

# Exclude local large media/test artifacts
*.mp4
*.mov
*.mkv
*.avi
*.wav
*.mp3
