{
  "name": "voiceflow-backend-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev-all": "node scripts/dev-all.mjs",
    "backend:start": "python app.py",
    "backend:install": "python -m pip install -r requirements.txt",
    "backend:install:voice-transfer": "python -m pip install -r engines/voice-transfer-runtime/requirements.txt",
    "services:bootstrap": "node scripts/bootstrap-services.mjs doctor",
    "services:bootstrap:gpu": "node scripts/bootstrap-services.mjs doctor --gpu",
    "services:check": "node scripts/bootstrap-services.mjs check",
    "services:doctor": "node scripts/bootstrap-services.mjs doctor",
    "services:restart": "node scripts/bootstrap-services.mjs restart",
    "services:down": "node scripts/bootstrap-services.mjs down",
    "models:kokoro:sync": "node scripts/sync-kokoro-model-mirror.mjs",
    "audit:frontend:errors": "node scripts/audit-frontend-errors.mjs --min-words 100",
    "audit:secrets:tracked-config": "node scripts/scan-tracked-secrets.mjs",
    "audit:gemini-stack": "node scripts/audit-gemini-stack.mjs",
    "audit:connectivity": "node scripts/audit-connectivity.mjs",
    "audit:media": "node scripts/audit-media-backend.mjs",
    "validate:k8s": "node scripts/validate-k8s-manifests.mjs",
    "download:voice-profiles": "node scripts/download-voice-profiles.mjs",
    "download:video:pipeline:assets": "node scripts/download-video-pipeline-assets.mjs",
    "download:video:pipeline:assets:force": "node scripts/download-video-pipeline-assets.mjs --force",
    "download:voice-transfer:models": "node scripts/download-voice-transfer-models.mjs",
    "download:voice-transfer:models:force": "node scripts/download-voice-transfer-models.mjs --force",
    "generate:voice-profiles": "node scripts/generate-voice-profile-references.mjs",
    "migrate:voice-map:voice-transfer": "node scripts/migrate-voice-map-voice-transfer.mjs",
    "benchmark:voice-transfer": "node scripts/benchmark-voice-transfer.mjs",
    "test:contracts": "node scripts/test-runtime-contracts.mjs",
    "test:tts:hindi-30s": "node scripts/test-tts-hindi-30s.mjs",
    "audit:tts:hindi": "node scripts/test-tts-hindi-30s.mjs",
    "audit:tts:all-engines:live": "node scripts/audit-tts-all-engines-live.mjs",
    "audit:tts:post-voice-transfer:30s": "node scripts/audit-tts-post-voice-transfer-30s.mjs",
    "test:tts:gemini-key-burst:live": "node scripts/test-gemini-key-burst-live.mjs",
    "audit:tts:longtext:smoke": "node scripts/test-tts-longtext-5000.mjs --mode smoke",
    "audit:tts:longtext:matrix": "node scripts/test-tts-longtext-5000.mjs --mode matrix",
    "audit:tts:live": "npm run audit:frontend:errors -- --suite tts-live",
    "audit:tts:live:10": "npm run audit:frontend:errors -- --suite tts-live-10",
    "audit:tts:live:50": "npm run audit:frontend:errors -- --suite tts-live-50",
    "audit:voice-transfer:mapping": "npm run audit:frontend:errors -- --suite voice-transfer-mapping",
    "test:tts:voice-transfer:multispeaker": "node scripts/test-tts-voice-transfer-multispeaker.mjs",
    "test:load:50:node": "node scripts/loadtest-tts-concurrency.mjs --mode mixed --concurrency 50 --requests 50",
    "test:load:50:k6": "node scripts/run-k6-load.mjs --mode mixed --vus 50 --duration 30s",
    "test:load:50:all": "npm run test:load:50:node && npm run test:load:50:k6",
    "test:load:100:node": "node scripts/loadtest-tts-concurrency.mjs --mode mixed --concurrency 100 --requests 100",
    "test:load:100:k6": "node scripts/run-k6-load.mjs --mode mixed --vus 100 --duration 30s",
    "test:load:100:all": "npm run test:load:100:node && npm run test:load:100:k6",
    "ci:reliability": "node scripts/ci-reliability.mjs",
    "audit:cpu:background": "npm run audit:frontend:errors -- --suite cpu-background",
    "audit:function-manifests": "node scripts/generate-function-manifests.mjs",
    "audit:stress:matrix": "node scripts/run-stress-matrix.mjs",
    "audit:bootstrap:idempotency": "npm run audit:frontend:errors -- --suite bootstrap-idempotency",
    "backfill:engine-display:prime": "node scripts/backfill-engine-display-prime.mjs",
    "pytest": "python -m pytest tests"
  }
}
