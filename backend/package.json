{
  "name": "voice-flow-cloudflare-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node dev-server.mjs",
    "start": "node dev-server.mjs",
    "dev:worker": "wrangler dev --config wrangler.jsonc",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "check": "node --check src/index.js && node --check src/env.js && node --check src/routes.js && node --check dev-server.mjs",
    "test": "node --test tests/contract.test.mjs"
  },
  "dependencies": {
    "hono": "^4.6.10"
  },
  "devDependencies": {
    "wrangler": "^4.86.0"
  }
