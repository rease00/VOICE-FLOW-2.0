{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "voice-flow-cloudflare-backend",
  "main": "src/index.js",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "BOOTSTRAP_SEED_SOURCE": "wrangler-canonical-admins",
    "BOOTSTRAP_ADMIN_SHARED_PASSWORD_HASH": "pbkdf2_sha256$100000$dmYtYWRtaW4tc2VlZC12MQ$aR2Q9Us6DOkajGyGDYSbTMppp2Q87ApZzwVuJ5ggTr0",
    "BOOTSTRAP_ADMIN_USERS_JSON": "{\"admins\":[{\"email\":\"admin1@vflowai.com\",\"roles\":[\"admin\"]},{\"email\":\"admin2@vflowai.com\",\"roles\":[\"admin\"]},{\"email\":\"admin3@vflowai.com\",\"roles\":[\"admin\"]},{\"email\":\"admin4@vflowai.com\",\"roles\":[\"admin\"]}]}",
    "VF_READER_STORAGE_BACKEND": "r2",
    "VF_READER_STORAGE_BUCKET_BINDING": "ARTIFACTS_BUCKET",
    "VF_TTS_PROVIDER": "openai-compatible",
    "VF_TTS_OPENAI_BASE_URL": "https://api.deepinfra.com/v1/openai",
    "VF_TTS_OPENAI_MODEL": "ResembleAI/chatterbox-multilingual",
    "VF_TTS_OPENAI_VOICE": "None",
    "VF_TTS_DEFAULT_ENGINE": "ResembleAI/chatterbox-multilingual",
    "VF_TTS_CALLBACK_BASE_URL": "https://voice-flow-cloudflare-frontend.1wasim9851229685.workers.dev"
  },
  "assets": {
    "directory": "../assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "v-flow-native-backend-db-current",
      "database_id": "34913ed3-8f57-42ef-8289-c9d457a7d977"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ARTIFACTS_BUCKET",
      "bucket_name": "voice-flow-cloudflare-backend-artifacts"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "JOB_QUEUE",
        "queue": "v-flow-domain-jobs"
      }
    ],
    "consumers": [
      {
        "queue": "v-flow-domain-jobs",
        "max_batch_size": 10,
        "max_batch_timeout": 30,
        "max_retries": 3
      }
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "JOB_COORDINATOR",
        "class_name": "JobCoordinator"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1-job-coordinator",
      "new_sqlite_classes": [
        "JobCoordinator"
      ]
    }
  ]
}
