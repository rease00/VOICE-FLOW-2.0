{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": [
      "@cloudflare/workers-types",
      "node",
      "vite/client"
    ]
  },
  "include": [
    "app/root.tsx",
    "app/global.css",
    "app/lib/**/*",
    "app/routes.ts",
    "app/routes/_scaffold/**/*",
    "workers/**/*",
    "react-router.config.ts",
    "vite.config.ts",
    "virtual-react-router.d.ts",
    "worker-configuration.d.ts"
  ]
}
