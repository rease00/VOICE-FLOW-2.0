{
  "name": "copy-of-voiceflow-pre",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:ui": "next dev --webpack",
    "build": "next build --webpack && node scripts/prune-bundled-audio.mjs && opennextjs-cloudflare build --skipBuild && node scripts/prune-cloudflare-browser-deps.mjs && node scripts/create-pages-dist.mjs",
    "start": "next start",
    "preview": "next start",
    "cloudflare:build": "node scripts/verify-cloudflare-workers.mjs && npm run build",
    "cloudflare:preview": "npm run cloudflare:build && opennextjs-cloudflare preview",
    "cloudflare:deploy": "npm run cloudflare:build && opennextjs-cloudflare deploy",
    "cloudflare:verify": "node scripts/verify-cloudflare-workers.mjs",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "verify:single-frontend": "node scripts/verify-single-frontend.mjs",
    "clean:frontend-artifacts": "node scripts/clean-frontend-artifacts.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "test:ci": "vitest run",
    "audit:prod": "npm run typecheck && npm run lint && npm run test:ci && npm run build",
    "e2e:smoke": "playwright test",
    "headers:verify": "node scripts/verify-headers.mjs",
    "bundle:report": "node scripts/bundle-report.mjs",
    "bundle:budget": "node scripts/bundle-budget.mjs",
    "perf:lighthouse": "node scripts/perf-lighthouse.mjs",
    "services:bootstrap": "npm --prefix ../backend run services:bootstrap",
    "services:bootstrap:gpu": "npm --prefix ../backend run services:bootstrap:gpu",
    "services:check": "npm --prefix ../backend run services:check",
    "services:doctor": "npm --prefix ../backend run services:doctor",
    "services:restart": "npm --prefix ../backend run services:restart",
    "services:down": "npm --prefix ../backend run services:down"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "eslint-config-next": "^16.2.1",
    "firebase": "^11.3.1",
    "lucide-react": "^0.554.0",
    "next": "^16.2.1",
    "onnxruntime-node": "file:./stubs/onnxruntime-node",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "kokoro-js": "^1.2.1",
    "postcss": "^8.5.6",
    "onnxruntime-common": "^1.22.0-dev.20250409-89f8206ba4",
    "onnxruntime-web": "^1.22.0-dev.20250409-89f8206ba4",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.77.0"
  }
}
