{
  "name": "v-flow-ai-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "node scripts/run-next-dev-with-guard.mjs --turbopack",
    "dev:ui": "node scripts/run-next-dev-with-guard.mjs --turbopack",
    "dev:webpack": "node scripts/run-next-dev-with-guard.mjs --webpack",
    "build": "next build && node scripts/prune-bundled-audio.mjs",
    "build:cloudflare": "next build && node scripts/prune-bundled-audio.mjs",
    "build:deploy": "npm run build && opennextjs-cloudflare build --skipBuild && node scripts/create-pages-dist.mjs",
    "start": "node scripts/prepare-standalone-runtime.mjs && node scripts/run-standalone-server.mjs",
    "preview": "node scripts/prepare-standalone-runtime.mjs && node scripts/run-standalone-server.mjs",
    "cloudflare:build": "node scripts/verify-cloudflare-workers.mjs && node scripts/run-cloudflare-build.mjs",
    "cloudflare:preview": "npm run cloudflare:build && opennextjs-cloudflare build --skipBuild && opennextjs-cloudflare preview",
    "cloudflare:deploy": "npm run cloudflare:build && opennextjs-cloudflare build --skipBuild && opennextjs-cloudflare deploy",
    "cloudflare:verify": "node scripts/verify-cloudflare-workers.mjs",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "verify:single-frontend": "node scripts/verify-single-frontend.mjs",
    "clean:frontend-artifacts": "node scripts/clean-frontend-artifacts.mjs",
    "typecheck": "next typegen && tsc --noEmit --project tsconfig.typecheck.json",
    "maintainability:check": "node scripts/check-module-size.mjs",
    "lint": "npx eslint . --ext .ts,.tsx",
    "test:ci": "vitest run",
    "audit:prod": "npm run typecheck && npm run lint && npm run maintainability:check && npm run test:ci && npm run build",
    "e2e:smoke": "node scripts/run-playwright-smoke.mjs launch",
    "e2e:smoke:md": "node scripts/run-playwright-smoke.mjs md",
    "e2e:smoke:full": "node scripts/run-playwright-smoke.mjs full",
    "audit:desktop": "node scripts/desktop-visual-audit.mjs",
    "headers:verify": "node scripts/verify-headers.mjs",
    "bundle:report": "node scripts/bundle-report.mjs",
    "bundle:budget": "node scripts/bundle-budget.mjs",
    "perf:lighthouse": "node scripts/perf-lighthouse.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1024.0",
    "@aws-sdk/s3-request-presigner": "3.1024.0",
    "@google-cloud/text-to-speech": "6.4.0",
    "@google/genai": "1.41.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/ws": "8.18.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "crypto-js": "4.2.0",
    "eslint-config-next": "15.5.15",
    "firebase": "11.10.0",
    "firebase-admin": "13.8.0",
    "framer-motion": "12.38.0",
    "idb": "8.0.3",
    "lucide-react": "1.11.0",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.5.0",
    "vaul": "^1.1.2",
    "ws": "8.18.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.1",
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "4.1.18",
    "@types/crypto-js": "4.2.2",
    "@types/node": "22.14.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@typescript-eslint/parser": "8.58.2",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.3",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "postcss": "8.5.6",
    "tailwindcss": "4.1.18",
    "tailwindcss-animate": "1.0.7",
    "ts-morph": "28.0.0",
    "typescript": "5.8.3",
    "vite": "6.4.1",
    "vitest": "3.2.4",
    "wrangler": "4.83.0"
  }
}
