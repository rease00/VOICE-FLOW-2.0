{
  "name": "copy-of-voiceflow-pre",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ui": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "test:ci": "vitest run",
    "audit:prod": "npm run typecheck && npm run lint && npm run test:ci && npm run build",
    "e2e:smoke": "playwright test",
    "headers:verify": "node scripts/verify-headers.mjs",
    "bundle:report": "node scripts/bundle-report.mjs",
    "bundle:budget": "node scripts/bundle-budget.mjs",
    "perf:lighthouse": "node scripts/perf-lighthouse.mjs",
    "services:bootstrap": "npm --prefix ../backend run services:bootstrap",
    "services:bootstrap:gpu": "npm --prefix ../backend run services:bootstrap:gpu",
    "services:check": "npm --prefix ../backend run services:check",
    "services:doctor": "npm --prefix ../backend run services:doctor",
    "services:restart": "npm --prefix ../backend run services:restart",
    "services:down": "npm --prefix ../backend run services:down"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "firebase": "^11.3.1",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
