{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "voice-flow-cloudflare-frontend",
  "main": "./workers/app.ts",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "services": [
    {
      "binding": "BACKEND",
      "service": "voice-flow-cloudflare-backend"
    }
  ]
}
