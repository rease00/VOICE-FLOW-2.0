rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Users ───
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Sub-collections under user
      match /{subcollection=**} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ─── Published Books (public read, author-only write) ───
    match /publishedBooks/{bookId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // Chapters
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/publishedBooks/$(bookId)).data.authorId == request.auth.uid;
      }
    }

    // ─── Ratings (one per user per book+chapter, user read/write own) ───
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── Financial: transactions (server-only writes) ───
    match /transactions/{txId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false; // server-only via Admin SDK
    }

    // ─── Financial: withdrawals (server-only writes) ───
    match /withdrawals/{wId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false; // server-only via Admin SDK
    }

    // ─── Referrals (server-only writes, user read own) ───
    match /referrals/{rId} {
      allow read: if request.auth != null
        && (resource.data.referrerId == request.auth.uid
            || resource.data.referredUserId == request.auth.uid);
      allow write: if false; // server-only
    }

    // ─── Notifications (user reads own, server-only creates) ───
    match /notifications/{userId}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt', 'dismissedAt']);
      allow create, delete: if false; // server-only
    }

    // ─── Agreements (user reads own, server-only writes) ───
    match /agreements/{aId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false; // server-only
    }

    // ─── Daily unlocks (user reads own, server creates) ───
    match /dailyUnlocks/{userId}/{date} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // server-only
    }

    // ─── Chapter unlocks (user reads own) ───
    match /chapterUnlocks/{unlockId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false; // server-only
    }

    // ─── KYC (server-only) ───
    match /kyc/{kycId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false; // server-only
    }

    // ─── Default deny ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
