{
  "name": "v-flow-ai-workspace-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "frontend": "npm --prefix frontend run",
    "backend": "npm --prefix backend run",
    "start:frontend": "npm run frontend -- dev:ui",
    "start:backend": "npm run backend -- services:bootstrap",
    "start:backend:gpu": "npm run backend -- services:bootstrap:gpu",
    "cloudflare:build": "npm run frontend -- cloudflare:build",
    "cloudflare:deploy": "npm run frontend -- cloudflare:deploy",
    "dev": "npm --prefix backend run dev-all",
    "dev:ui": "npm --prefix frontend run dev:ui",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview",
    "frontend:verify:single": "npm --prefix frontend run verify:single-frontend",
    "frontend:clean:artifacts": "npm --prefix frontend run clean:frontend-artifacts",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "frontend:audit:prod": "npm --prefix frontend run audit:prod",
    "ci:frontend:phase1": "npm run frontend:verify:single && npm run frontend:build && npm run frontend:typecheck && npm run frontend:audit:prod",
    "ci:frontend:phase2": "npm run ci:frontend:phase1 && npm --prefix frontend run lint && npm --prefix frontend run test:ci",
    "ci:frontend:phase3": "npm run ci:frontend:phase2 && npm --prefix frontend run e2e:smoke && npm --prefix frontend run perf:lighthouse",
    "backend:start": "npm --prefix backend run backend:start",
    "backend:install": "npm --prefix backend run backend:install",
    "services:bootstrap": "npm --prefix backend run services:bootstrap",
    "services:bootstrap:gpu": "npm --prefix backend run services:bootstrap:gpu",
    "services:check": "npm --prefix backend run services:check",
    "services:doctor": "npm --prefix backend run services:doctor",
    "services:restart": "npm --prefix backend run services:restart",
    "services:down": "npm --prefix backend run services:down",
    "audit:auth:bootstrap": "npm --prefix backend run audit:auth:bootstrap",
    "audit:gemini-stack": "npm --prefix backend run audit:gemini-stack",
    "audit:secrets:tracked-config": "npm --prefix backend run audit:secrets:tracked-config",
    "audit:secrets:staged": "node scripts/scan-staged-secrets.mjs",
    "audit:secrets": "npm run audit:secrets:staged && npm run audit:secrets:tracked-config",
    "precommit:secrets": "npm run audit:secrets:staged",
    "audit:connectivity": "npm --prefix backend run audit:connectivity",
    "audit:media": "npm --prefix backend run audit:media",
    "validate:k8s": "npm --prefix backend run validate:k8s",
    "download:voice-profiles": "npm --prefix backend run download:voice-profiles",
    "test:contracts": "npm --prefix backend run test:contracts",
    "audit:tts:hindi": "npm --prefix backend run audit:tts:hindi",
    "audit:tts:all-engines:live": "npm --prefix backend run audit:tts:all-engines:live",
    "audit:tts:longtext:smoke": "npm --prefix backend run audit:tts:longtext:smoke",
    "audit:tts:longtext:matrix": "npm --prefix backend run audit:tts:longtext:matrix",
    "test:load:50:node": "npm --prefix backend run test:load:50:node",
    "test:load:50:k6": "npm --prefix backend run test:load:50:k6",
    "test:load:50:all": "npm --prefix backend run test:load:50:all",
    "test:load:12:node": "npm --prefix backend run test:load:12:node",
    "test:load:100:node": "npm --prefix backend run test:load:100:node",
    "test:load:100:k6": "npm --prefix backend run test:load:100:k6",
    "test:load:100:all": "npm --prefix backend run test:load:100:all",
    "ci:reliability": "npm --prefix backend run ci:reliability",
    "audit:cpu:background": "npm --prefix backend run audit:cpu:background",
    "audit:function-manifests": "npm --prefix backend run audit:function-manifests",
    "audit:stress:matrix": "npm --prefix backend run audit:stress:matrix",
    "hooks:install": "git config core.hooksPath .githooks"
  }
}
